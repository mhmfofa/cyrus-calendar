  },
  "homepage": "https://github.com/mhmfofa/cyrus-calendar#readme",
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/forms": ">=17.0.0",
