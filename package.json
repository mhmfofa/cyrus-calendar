{
  "name": "ng-cyrus-calendar-workspace",
  "version": "1.1.2",
  "private": true,
  "description": "Workspace / demo app for ng-cyrus-calendar. NOT the publishable library — publish from dist/cyrus-calendar instead.",
  "author": "Mohammadhassan Molayemi",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng-packagr -p libs/cyrus-calendar/ng-package.json && node -e \"require('fs').copyFileSync('README.md','dist/cyrus-calendar/README.md');require('fs').copyFileSync('CHANGELOG.md','dist/cyrus-calendar/CHANGELOG.md')\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "peerDependencies": {
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/common": ">=21.0.0",
    "@angular/compiler": "^21.2.1",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "bootstrap": "^5.3.8",
    "jalaali-js": "^2.0.0",
    "moment": "^2.30.1",
    "moment-hijri": "^3.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@types/jasmine": "^5.1.6",
    "@types/node": "^22.0.0",
    "jasmine-core": "^5.4.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "^21.2.0",
    "typescript": "~5.9.3"
  }
}
